# Laravel API root (same as Postman {{base_url}} — must include /api)
VITE_API_URL=http://127.0.0.1:8000/api

# Production dashboard on Vercel: api-origin.ts auto-uses `/api` (vercel.json rewrite).
# All rich-editor saves and image uploads then go same-origin (blogs, services, hero, …).
# Optional override if you host the dashboard elsewhere:
# VITE_API_URL=/api
# VITE_API_ORIGIN=https://howeyah.subcodeco.com

# Local dev against production API (vite.config.ts proxies /api → howeyah host):
# VITE_API_URL=/api

# If GET /v1/admin/blogs returns 404/5xx but GET /v1/blogs works, set true to use the public list
# when not in dev. (In `npm run dev`, this fallback runs automatically.)
# VITE_USE_PUBLIC_BLOGS_FALLBACK=true
