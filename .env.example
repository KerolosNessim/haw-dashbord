# Local dev only — production uses `/api` via vercel.json (no env var required on Vercel).
VITE_API_URL=http://127.0.0.1:8000/api

# Optional: dev against production API through vite proxy (vite.config.ts):
# VITE_API_URL=/api

# Optional: storage/media host when using relative /api in dev
# VITE_API_ORIGIN=https://howeyah.subcodeco.com

# If GET /v1/admin/blogs returns 404/5xx but GET /v1/blogs works, set true to use the public list
# when not in dev. (In `npm run dev`, this fallback runs automatically.)
# VITE_USE_PUBLIC_BLOGS_FALLBACK=true
